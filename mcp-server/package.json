{
  "name": "ttobak-mcp",
  "version": "1.0.0",
  "description": "Ttobak MCP server for Claude Code — meeting data access with Cognito OAuth PKCE",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/ttobak-mcp.mjs --banner:js=\"#!/usr/bin/env node\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
