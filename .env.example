# =============================================
# Ttobak Environment Variables
# Copy to frontend/.env.local for frontend dev
# Backend env vars are injected by CDK at deploy time
# =============================================

# Frontend (frontend/.env.local)
NEXT_PUBLIC_API_URL=https://your-cloudfront-domain.cloudfront.net
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WEBSOCKET_URL=wss://your-api-id.execute-api.ap-northeast-2.amazonaws.com/production

# Backend (set by CDK — shown for reference only)
# TABLE_NAME=ttobak-main
# BUCKET_NAME=ttobak-assets-{accountId}
# KB_BUCKET_NAME=ttobak-kb-{accountId}
# BEDROCK_MODEL_ID=anthropic.claude-opus-4-6-20250515-v1:0
# KB_ID=your-kb-id
# KB_DATASOURCE_ID=your-datasource-id
# COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# KMS_KEY_ID=your-kms-key-id
