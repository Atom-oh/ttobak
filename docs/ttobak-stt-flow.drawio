        <!-- EventBridge -> Transcribe Lambda -->
        <mxCell id="f2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#FF6600;" edge="1" source="eb" target="tLambda" parent="1">
