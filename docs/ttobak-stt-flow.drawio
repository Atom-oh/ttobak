        <!-- Transcribe Lambda -> Branch A -->
        <mxCell id="f3" value="parallel" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82B366;fontSize=10;" edge="1" source="tLambda" target="transcribeJob" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Transcribe Lambda -> Branch B -->
        <mxCell id="f4" value="parallel" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#D6A461;fontSize=10;" edge="1" source="tLambda" target="novaSonic" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- TranscribeJob -> S3 transcript -->
        <mxCell id="f5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1;strokeColor=#82B366;" edge="1" source="transcribeJob" target="s3transcript" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- S3 transcript -> DDB A -->
        <mxCell id="f6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1;strokeColor=#82B366;" edge="1" source="s3transcript" target="ddbA" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Nova 2 Sonic -> DDB B -->
        <mxCell id="f7" value="direct write" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1;strokeColor=#D6A461;fontSize=9;" edge="1" source="novaSonic" target="ddbB" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- DDB -> DDB Stream (summarize trigger) -->
        <mxCell id="f8" value="Stream" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673A6;fontSize=10;" edge="1" source="ddbA" target="ddbStream" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="930" y="500" />
              <mxPoint x="150" y="500" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- DDB Stream -> Summarize Lambda -->
        <mxCell id="f9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673A6;" edge="1" source="ddbStream" target="sumLambda" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Summarize Lambda -> Bedrock -->
        <mxCell id="f10" value="InvokeModel" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673A6;fontSize=10;" edge="1" source="sumLambda" target="bedrock" parent="1">
          <mxGeometry relative="1" as="geometry" />
