        <mxCell id="statusLabel" value="&lt;b&gt;Status Flow:&lt;/b&gt;  recording → &lt;font color=&quot;#FF6600&quot;&gt;&lt;b&gt;transcribing&lt;/b&gt;&lt;/font&gt; → &lt;font color=&quot;#9673A6&quot;&gt;&lt;b&gt;summarizing&lt;/b&gt;&lt;/font&gt; → &lt;font color=&quot;#82B366&quot;&gt;&lt;b&gt;done&lt;/b&gt;&lt;/font&gt;" style="text;html=1;fontSize=13;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
