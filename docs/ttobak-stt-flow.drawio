        <mxCell id="branchAlabel" value="&lt;b&gt;Branch A: Amazon Transcribe&lt;/b&gt;" style="text;html=1;fontSize=11;fillColor=none;strokeColor=none;fontColor=#2D6A2E;" vertex="1" parent="1">
          <mxGeometry x="710" y="155" width="240" height="20" as="geometry" />
