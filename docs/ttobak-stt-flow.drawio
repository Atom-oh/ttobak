        <mxCell id="transcribeJob" value="StartTranscription&lt;br&gt;Job (한/영)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.transcribe;labelBackgroundColor=none;sketch=0;html=1;fontSize=10;" vertex="1" parent="1">
