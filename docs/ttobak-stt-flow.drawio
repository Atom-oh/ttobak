          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- A/B note -->
        <mxCell id="abnote" value="&lt;b&gt;A/B 비교&lt;/b&gt;&lt;br&gt;• 모든 회의에 언어 무관 실행&lt;br&gt;• 사용자가 A 또는 B 선택 가능&lt;br&gt;• 선택된 결과로 요약 실행" style="text;html=1;fontSize=10;align=left;verticalAlign=top;rounded=1;whiteSpace=wrap;fillColor=#FFFFCC;strokeColor=#E6DB00;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
