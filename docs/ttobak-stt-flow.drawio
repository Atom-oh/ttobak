        <mxCell id="branchBlabel" value="&lt;b&gt;Branch B: Amazon Nova 2 Sonic&lt;/b&gt;" style="text;html=1;fontSize=11;fillColor=none;strokeColor=none;fontColor=#B45F06;" vertex="1" parent="1">
