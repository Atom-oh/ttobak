          <mxGeometry x="700" y="345" width="50" height="50" as="geometry" />
        </mxCell>

        <mxCell id="ddbB" value="DynamoDB&lt;br&gt;transcriptB" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;labelBackgroundColor=none;sketch=0;html=1;fontSize=10;" vertex="1" parent="1">
