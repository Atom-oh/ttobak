          <mxGeometry x="40" y="530" width="960" height="180" as="geometry" />
        </mxCell>
        <mxCell id="phase3label" value="Phase 3: Summarization" style="text;html=1;fontSize=12;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="50" y="535" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- DDB Stream trigger -->
        <mxCell id="ddbStream" value="DynamoDB Stream&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;status = &quot;summarizing&quot;&lt;/font&gt;" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;labelBackgroundColor=none;sketch=0;html=1;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="590" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Summarize Lambda -->
        <mxCell id="sumLambda" value="Lambda&lt;br&gt;(Summarize)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Timeout: 120s&lt;/font&gt;" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;labelBackgroundColor=none;sketch=0;html=1;fontStyle=1;fontSize=11;fillColor=#E6D5F5;" vertex="1" parent="1">
          <mxGeometry x="330" y="590" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Bedrock Claude -->
        <mxCell id="bedrock" value="Bedrock&lt;br&gt;Claude Opus 4.6&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;구조화된 회의록 생성&lt;/font&gt;" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock;labelBackgroundColor=none;sketch=0;html=1;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="590" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- DynamoDB (result) -->
        <mxCell id="ddbResult" value="DynamoDB&lt;br&gt;content (Markdown)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;status → &quot;done&quot;&lt;/font&gt;" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;labelBackgroundColor=none;sketch=0;html=1;fontStyle=1;fontSize=10;fillColor=#D5E8D4;" vertex="1" parent="1">
          <mxGeometry x="800" y="590" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <!-- S3 -> EventBridge -->
        <mxCell id="f1" value="S3 Event" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;fontSize=10;" edge="1" source="s3upload" target="eb" parent="1">
          <mxGeometry relative="1" as="geometry" />
