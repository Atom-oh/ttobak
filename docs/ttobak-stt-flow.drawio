        <mxCell id="ddbA" value="DynamoDB&lt;br&gt;transcriptA" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;labelBackgroundColor=none;sketch=0;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="905" y="185" width="50" height="50" as="geometry" />
