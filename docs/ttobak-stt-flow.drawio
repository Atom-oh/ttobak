        <!-- Branch B: Nova 2 Sonic -->
        <mxCell id="branchBbox" value="" style="rounded=1;whiteSpace=wrap;fillColor=#FFE6CC;strokeColor=#D6A461;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="680" y="300" width="300" height="150" as="geometry" />
